# Copy to .env for local dev. The defaults in app/config.py are fine for
# running locally, but you MUST set SECRET_KEY in production.

DEBUG=true
SECRET_KEY=dev-only-change-me
DATABASE_URL=sqlite:///./data/coffee.db

# Branding (optional). APP_NAME renders as "name@domain" in the header.
# APP_NAME=caffeine@RCH
# TAGLINE=Enabling safe and smooth anaesthesia since 2026
