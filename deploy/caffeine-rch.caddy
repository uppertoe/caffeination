# caffeine@RCH -- office coffee orders. The app uses its own signed-cookie
# identity (no passwords), so it is served openly to anyone who can reach it.
# To put it behind the SSO gateway instead, add the line  import protected
# above the reverse_proxy (see apps/auth/auth.caddy).
#
# NOTE: keep comments in .caddy files free of braces -- the scaffold's
# run-caddy.sh counts braces when assembling the Caddyfile.
caffeine.{$DOMAIN} {
	reverse_proxy caffeine:8000
}
