# caffeine@RCH configuration.
# Copy to apps/caffeine-rch/.env on the server and fill in. Never commit the
# real .env -- the deploy helper sets it to mode 600 on the server.

# 32+ random bytes used to sign the identity cookie.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# DATABASE_URL and DEBUG are set in docker-compose.yml (SQLite on the mounted
# volume, debug off). Override here only if you really need to.
# DATABASE_URL=sqlite:////data/caffeine.db
# DEBUG=false

# Cookie name (optional; defaults to coffee_rch_id).
# COOKIE_NAME=caffeine_rch_id

# Branding (per-hospital). APP_NAME renders as "name@domain" in the header,
# split on the first @. Leave unset to use the caffeine@RCH defaults.
#   Royal Children's Hospital:
# APP_NAME=caffeine@RCH
# TAGLINE=Enabling safe and smooth anaesthesia since 2026
#   Monash Children's Hospital:
# APP_NAME=caffeine@Monash
# TAGLINE=Enabling safe and smooth anaesthesia since 2026
